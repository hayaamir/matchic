generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js required tables ───────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application User ──────────────────────────────────────────────────────

model User {
  // Auth.js required fields
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // Credentials provider password (null for OAuth users)
  password String?

  // Custom app fields
  firstName          String?
  lastName           String?
  phone              String?
  subscriptionPlan   SubscriptionPlan   @default(basic)
  subscriptionStatus SubscriptionStatus @default(trial)
  subscriptionExpiry DateTime?
  isActive           Boolean            @default(true)
  bio                String?
  specializations    Sector[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  userCandidates UserCandidate[]
  matchesAsUserA Match[]         @relation("UserAMatches")
  matchesAsUserB Match[]         @relation("UserBMatches")
}

// ─── Domain Tables ──────────────────────────────────────────────────────────

model Candidate {
  id          String          @id @default(cuid())
  firstName   String
  lastName    String
  fullName    String?
  gender      Gender
  idNumber    String          @unique
  phone       String
  dateOfBirth String
  sector      Sector          @default(chabad)
  status      CandidateStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userCandidates  UserCandidate[]
  candidateImages CandidateImage[]
  matchesAsA      Match[]          @relation("CandidateAMatches")
  matchesAsB      Match[]          @relation("CandidateBMatches")
}

model CandidateImage {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  url         String
  format      String    @default("image")
  uploadedAt  DateTime  @default(now())
}

model UserCandidate {
  id          String    @id @default(cuid())
  userId      String
  candidateId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([userId, candidateId])
}

model Match {
  id           String      @id @default(cuid())
  candidateAId String
  candidateBId String
  userAId      String
  userBId      String
  status       MatchStatus @default(active)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidateA Candidate @relation("CandidateAMatches", fields: [candidateAId], references: [id])
  candidateB Candidate @relation("CandidateBMatches", fields: [candidateBId], references: [id])
  userA      User      @relation("UserAMatches", fields: [userAId], references: [id])
  userB      User      @relation("UserBMatches", fields: [userBId], references: [id])
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Gender {
  male
  female
}

enum Sector {
  chabad
}

enum CandidateStatus {
  active
  in_date
  found_match
  on_hold
}

enum MatchStatus {
  active
  not_match
  matched
}

enum SubscriptionPlan {
  basic
  premium
  pro
}

enum SubscriptionStatus {
  active
  expired
  trial
}
